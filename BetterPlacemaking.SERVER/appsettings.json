{
  "Firebase": {
    "ProjectId": "better-placemaking-vision",
    "Database": "(default)"
  },
  "Jwt": {
    "Issuer": "BetterPlacemaking",
    "Audience": "BetterPlacemaking.Client",
    "ExpiresMinutes": 60
  },
  "ApiBaseUrl": "http://localhost:5123",
  "Notifications": {
    "AppBaseUrl": "http://localhost:4200"
  },
  "Gcs": {
    "BucketName": "better-placemaking-vision.firebasestorage.app",
    "UrlTtlMinutes": 10080,
    "BasePrefix": "uploads"
  },
  "Redis": {
    "Configuration": "",
    "InstanceName": "BetterPlacemaking:"
  },
  "RplidarScan": {
    "ScanDirectory": "Data/rplidar_scans",
    "FloorThreshold": -4.3,
    "CeilingThreshold": -1.0,
    "ClusterGridSize": 0.4,
    "MinClusterPoints": 10,
    "WallMargin": 0.8,
    "ScannerExclusionRadius": 2,
    "GroundContactMargin": 0.9,
    "MaxObstacleDimension": 5
  },
  "Tracking": {
    "PositionsCsv": "Data/positions.csv",
    "TracksDir": "Data/tracks",
    "OffsetX": 0,
    "OffsetY": 0,
    "OffsetZ": 0,
    "RotationAngle": 0,
    "ScaleX": 1,
    "ScaleZ": 1
  },
  "Visualizer": {
    "ScanIngest": {
      "AllowedHosts": [],
      "XyzUnits": "m",
      "MaxDownloadBytes": 209715200
    }
  }
}
